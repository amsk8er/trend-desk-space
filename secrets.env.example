# Copy to secrets.env (gitignored) and fill in.
# Generate the token once with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=REPLACE_ME

# 节点⑩飞书推送（应用凭证，后端直调把日报导入为云文档）。
# app_id/app_secret：开发者后台 → 自建应用 → 凭证与基础信息；需开通 drive:drive 权限并发布版本。
FEISHU_APP_ID=REPLACE_ME
FEISHU_APP_SECRET=REPLACE_ME
# FEISHU_FOLDER_TOKEN：云文档落地位置。可选——
#   留空 = 挂到应用自己的云空间根目录（飞书个人版无法把应用加成文件夹协作者，用这条；已验证可推可看）。
#   填值 = 挂到指定文件夹（企业版可用：先在云文档「…更多 → 添加文档应用」把应用加成可编辑协作者）。
FEISHU_FOLDER_TOKEN=
# FEISHU_BASE=https://open.feishu.cn/open-apis   # 海外租户改 https://open.larksuite.com/open-apis

# 节点⑨日报 LLM 趋势研判（自动+缓存；走 LLM_BACKEND，默认 claude_cli=chat 同款，无需额外 key）。
# 失败/未配置时优雅降级（日报照常出，附「未生成」提示）。anthropic_api 后端才需 ANTHROPIC_API_KEY。
# TREND_BRIEF_ENABLED=true        # 设 false 可关掉研判段，日报回到纯机械
# TREND_BRIEF_LOOKBACK=5          # 市场节奏/板块趋势回看 batch 数
# TREND_BRIEF_MODEL=claude-sonnet-4-6   # 默认随 CHAT_MODEL；控成本
# ANTHROPIC_API_KEY=sk-ant-...    # 仅当 LLM_BACKEND=anthropic_api 时需要

# 持仓截图视觉后端（交易台可逐次选择，不需要改全局 LLM_BACKEND）：
# 1) MiniMax Coding Plan：安装官方 MiniMax CLI 后运行
#    `mmx auth login --api-key <Token Plan Key>`。
#    若 mmx 不在 PATH，可显式指定可执行文件；密钥由 CLI 自己保管，不进入前端。
# MINIMAX_CLI_BIN=/absolute/path/to/mmx
#
# 2) 任意支持 OpenAI chat/completions + image_url 的视觉模型：
# OPENAI_COMPATIBLE_BASE_URL=https://provider.example/v1
# OPENAI_COMPATIBLE_API_KEY=REPLACE_ME
# OPENAI_COMPATIBLE_VISION_MODEL=provider-vision-model
#
# 3) AI Builder Space 部署：
# 平台会自动注入 AI_BUILDER_TOKEN。后端自动切到 openai_compatible，
# 使用 https://space.ai-builders.com/backend/v1 的 kimi-k2.5 视觉能力。
# 同一个 Token 只在服务端用于 API 调用和私人访问登录，不进入浏览器源码。
# AI_BUILDER_TOKEN=
# 挂载到已有网站子路径时设置前端构建基址，例如 /trend-desk/。
# VITE_BASE_PATH=/
# 可选：本机纪律原文路径。线上未挂载原文时保持为空，网页仍展示内置机器规则。
# DISCIPLINE_RULES_SOURCE_PATH=/absolute/path/to/discipline.md
# 趋势动物官方 API（仅后端使用；不要放前端、日志或仓库真实值）
TREND_ANIMALS_API_KEY=
TREND_ANIMALS_ENABLED=false
TREND_ANIMALS_DEFAULT_BUDGET=0.50
TREND_ANIMALS_SELECTION_BUDGET=3.00
TREND_DAILY_SCHEDULER_ENABLED=false
TREND_DAILY_TIMEZONE=Asia/Shanghai
TREND_DAILY_START=16:30
TREND_DAILY_RETRY_MINUTES=30
TREND_DAILY_CUTOFF=20:00
TREND_ANIMALS_DAILY_AUTO_BUDGET=3.50
